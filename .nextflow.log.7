  CYTASSIST_IMAGE="$(find "$SAMPLE_DIR_ABS" -type f \( -name '*[Cc]yt[Aa]ssist*.tif' -o -name '*[Cc]yt[Aa]ssist*.tiff' \) -print -quit || true)"
